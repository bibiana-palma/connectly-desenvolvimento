# Exemplo de variáveis de ambiente para Supabase
# Substitua pelos valores do seu projeto Supabase
# Você pode obter estes valores no painel do Supabase → Settings → API

VITE_SUPABASE_URL=https://your-project.supabase.co
VITE_SUPABASE_PUBLISHABLE_KEY=your-anon-or-publishable-key

# Algumas partes do código podem também checar estas variáveis sem VITE_ prefix
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_PUBLISHABLE_KEY=your-anon-or-publishable-key
